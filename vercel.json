{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build && pnpm --filter api migration:run:prod",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@5",
      "includeFiles": "apps/api/src/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
